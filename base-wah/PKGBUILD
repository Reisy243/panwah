package(){
  cd "$pkgdir"
  #Creando el sistema de archivos raiz
  for d in boot dev etc home mnt usr var opt srv/http run; do
    install -d -m755 $d
  done
  install -d -m555 proc
  install -d -m555 sys
  install -d -m0750 root
  install -d -m1777 tmp
  # vsftpd no se ejecutará con permisos de escritura en /srv/ftp
  # ftp (uid 14/gid 11)
  install -d -m555 -g 11 srv/ftp

  #Creando la jerarquia de /usr
  for d in bin include lib share/{misc,pixmaps} src; do
    install -d -m755 usr/$d
  done
  for d in {1..8}; do
    install -d -m755 usr/share/man/man$d
  done

  #Creando la jerarquia de /usr/local
  for d in bin etc games include lib man sbin share src; do
    install -d -m755 usr/local/$d
  done
  ln -s ../man usr/local/share/man

  #Creando /var
  for d in cache local opt log/old lib/misc empty; do
    install -d -m755 var/$d
  done
  install -d -m1777 var/{tmp,spool/mail}

  #Permitir setgid games (gid 50) para escribir puntajes
  install -d -m775 -g 50 var/games
  ln -s spool/mail var/mail
  ln -s ../run var/run
  ln -s ../run/lock var/lock

  #Añadiendo el enlace simbolico a bin
  ln -s usr/bin bin
  ln -s usr/bin sbin
  ln -s bin usr/sbin
  
  #Añadiendo el enlace simbolico a lib
  ln -s usr/lib lib
  [[ $CARCH = 'x86_64' ]] && {
    ln -s usr/lib lib64
    ln -s lib usr/lib64
  }

  #Configurar /etc y /usr/share/factory/etc
  install -d etc/{ld.so.conf.d,skel,profile.d} usr/share/factory/etc
  for f in fstab group host.conf hosts issue ld.so.conf nsswitch.conf \
    passwd resolv.conf securetty shells profile; do
    install -m644 "$srcdir"/$f etc/
    install -m644 "$srcdir"/$f usr/share/factory/etc/
  done
  ln -s ../proc/self/mounts etc/mtab
  for f in gshadow shadow crypttab; do
    install -m600 "$srcdir"/$f etc/
    install -m600 "$srcdir"/$f usr/share/factory/etc/
  done
  echo "Panwah" > etc/wah-release
  install -m644 "$srcdir"/locale.sh etc/profile.d/locale.sh
  install -Dm644 "$srcdir"/os-release usr/lib/os-release

  #Creando systemd-sysctl
  install -D -m644 "$srcdir"/sysctl usr/lib/sysctl.d/10-wah.conf

  #Creando systemd-sysusers
  install -D -m644 "$srcdir"/sysusers usr/lib/sysusers.d/wah.conf

  #Creando systemd-tmpfiles
  install -D -m644 "$srcdir"/tmpfiles usr/lib/tmpfiles.d/wah.conf

  #Creando systemd.environment-generator
  install -D -m755 "$srcdir"/env-generator usr/lib/systemd/system-environment-generators/10-wah

  #Añadir logos
  install -Dm644 "$srcdir"/wah-logo{.png,.svg,-text.svg,-text-dark.svg} "$pkgdir/usr/share/pixmaps"
}